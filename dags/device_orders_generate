def clean_dataframe(data):
    df = pd.DataFrame(data)

    # Convert Decimal128 → float
    for col in ["Qty", "Discount", "Total"]:
        df[col] = df[col].apply(
            lambda x: float(x.to_decimal()) if hasattr(x, "to_decimal") else x
        )

    df["Order #"] = df["Order #"].astype(int)
    df["Qty"] = df["Qty"].astype(int)

    df["Discount"] = df["Discount"].round(2)
    df["Total"] = df["Total"].round(2)

    df["Ingest Date"] = pd.Timestamp.now(tz="America/Los_Angeles")

    return df


# ==============================
#  Build Summary
# ==============================
def build_summary_tables(df):

    df = df[df["Status"] != "Cancelled"].copy()

    tz = "America/Vancouver"
    ingest_date = pd.Timestamp.now(tz=tz).normalize()

    df["Date"] = pd.to_datetime(df["Date"]).dt.tz_localize("America/Vancouver")
    df["Date_only"] = df["Date"].dt.normalize()

    mtd_start = ingest_date.replace(day=1)
    ytd_start = ingest_date.replace(month=1, day=1)

    # ========= SUMMARY =========
    def count(x):
        return x["Qty"].sum()

    df_summary = pd.DataFrame(
        {
            "Metric": ["Units"],
            "Date": [count(df[df["Date_only"] == ingest_date])],
            "MTD": [
                count(
                    df[
                        (df["Date_only"] >= mtd_start)
                        & (df["Date_only"] <= ingest_date)
                    ]
                )
            ],
            "YTD": [
                count(
                    df[
                        (df["Date_only"] >= ytd_start)
                        & (df["Date_only"] <= ingest_date)
                    ]
                )
            ],
        }
    )

    # ========= PRODUCT =========
    def map_model(p):
        p_clean = p.lower().replace(" ", "").replace("-", "")
        
        if "modo" in p_clean:
            return "Modo"
        if "c2" in p_clean:
            return "Model C2"
        elif "modelf" in p_clean or p_clean == "f":
            return "Model F"
        elif "r3" in p_clean:
            return "Model R-3 wheel"
        elif "r4" in p_clean:
            return "Model R-4 wheel"
        else:
            return "Other"

    df["Product Type"] = df["Product"].apply(map_model)

    def agg(data):
        return data.groupby(["Product Type", "Product"])["Qty"].sum().reset_index()

    date_df = agg(df[df["Date_only"] == ingest_date]).rename(columns={"Qty": "Date"})
    mtd_df = agg(
        df[(df["Date_only"] >= mtd_start) & (df["Date_only"] <= ingest_date)]
    ).rename(columns={"Qty": "MTD"})
    ytd_df = agg(
        df[(df["Date_only"] >= ytd_start) & (df["Date_only"] <= ingest_date)]
    ).rename(columns={"Qty": "YTD"})

    df_product = date_df.merge(mtd_df, on=["Product Type", "Product"], how="outer")
    df_product = df_product.merge(ytd_df, on=["Product Type", "Product"], how="outer")
    df_product = df_product.fillna(0)

    return df_summary, df_product, ingest_date


