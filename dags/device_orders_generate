        "product",
        "qty",
        "discount",
        "total",
        "refund_detected_date",
        "channel",
        "assigned_isr",
        "sales_model",
        "customer_name",
        "status_yesterday",
        "status_change",
        "report_sent_date",
    ]

    df_refund = df_refund[final_cols]

    history_dir = os.path.join(path, "refund_history_tbl")
    os.makedirs(history_dir, exist_ok=True)

    history_file = os.path.join(history_dir, "refund_history.csv")

    if os.path.exists(history_file):
