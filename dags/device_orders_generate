def append_to_refund_history(**context):
    import pandas as pd
    import os
    from datetime import datetime, timedelta

    path = "/opt/airflow/output"

    files = [
        f
        for f in os.listdir(path)
        if f.startswith("device_orders_") and f.endswith(".xlsx")
    ]

    def extract_date(f):
        return datetime.strptime(f.split("_")[-1].replace(".xlsx", ""), "%Y-%m-%d")

    files_sorted = sorted(files, key=extract_date)

    if len(files_sorted) < 2:
        print("Not enough files to compare")
        return

    today = datetime.today().date()
    yesterday = today - timedelta(days=1)

    today_file = f"device_orders_{today}.xlsx"
    yesterday_file = f"device_orders_{yesterday}.xlsx"

    if today_file in files and yesterday_file in files:
        print("Using current_date logic")
        f_curr = os.path.join(path, today_file)
        f_prev = os.path.join(path, yesterday_file)
    else:
        print("Fallback to latest files")
        f_curr = os.path.join(path, files_sorted[-1])
        f_prev = os.path.join(path, files_sorted[-2])

    df_prev = pd.read_excel(f_prev, sheet_name="Source Data")
    df_curr = pd.read_excel(f_curr, sheet_name="Source Data")

    df_prev = df_prev.rename(columns={"Status": "status_yesterday"})
    df_curr = df_curr.rename(columns={"Status": "status_today"})

