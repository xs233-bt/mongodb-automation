def build_pipeline():
    return [
        {"$unwind": "$items"},
        {
            "$match": {
                "items.product.type.name": {
                    "$in": ["VA Mobility Products", "Mobility Products"]
                },
                "items.product.name": {
                    "$regex": "^(Model|Modo)",
                    "$options": "i"
                },
                "stage.name": {"$nin": ["Quote", "Ready for Sending"]},
            }
        },
        {
            "$addFields": {
                "order_date": {
                    "$toDate": {"$multiply": ["$key_dates.submitted_on", 1000]}
                }
            }
        },
        {
            "$project": {
                "_id": 0,
                "Date": "$order_date",
                "Order #": "$number",
                "Status": "$stage.name",
                "contact_id": "$contact_id",
                "Product": "$items.product.name",
                "Qty": "$items.quantity",
                "Discount": "$items.discount.amount",
                "Total": "$items.total",
                "Ingest Date": {"$toDate": "$_id"},
            }
        },
        {
            "$lookup": {
                "from": "ContactProfiles",
                "localField": "contact_id",
                "foreignField": "contact_id",
                "as": "contact",
            }
        },
        {"$unwind": {"path": "$contact", "preserveNullAndEmptyArrays": True}},
        {
            "$addFields": {
                "Channel": {
                    "$let": {
                        "vars": {
                            "match": {
                                "$arrayElemAt": [
                                    {
                                        "$filter": {
                                            "input": "$contact.custom_fields",
                                            "as": "cf",
                                            "cond": {
                                                "$eq": ["$$cf.key", "whill_b2b_channel"]
                                            },
                                        }
                                    },
                                    0,
                                ]
                            }
                        },
                        "in": "$$match.value",
                    }
                },
                "Assigned ISR": {
                    "$let": {
                        "vars": {
                            "match": {
                                "$arrayElemAt": [
                                    {
                                        "$filter": {
                                            "input": "$contact.custom_fields",
                                            "as": "cf",
                                            "cond": {
                                                "$eq": [
                                                    "$$cf.key",
                                                    "whill_b2b_isr_account",
                                                ]
                                            },
                                        }
                                    },
                                    0,
                                ]
                            }
                        },
                        "in": {"$ifNull": ["$$match.value", "NO_ISR"]},
                    }
                },
                "Sales Model": "$contact.sales_model.name",
                "Customer Name": "$contact.profile.name",
            }
        },
        {"$project": {"contact": 0, "contact_id": 0}},
        {"$sort": {"Date": -1}},
    ]


def fetch_data(col):
    return list(col.aggregate(build_pipeline()))


