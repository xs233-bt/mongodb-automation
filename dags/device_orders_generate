def build_refund_summary():

    import pandas as pd
    import os

    path = "/opt/airflow/output/refund_history_tbl/refund_history.csv"

    if not os.path.exists(path):
        return pd.DataFrame()

    df = pd.read_csv(path)

    if df.empty:
        return pd.DataFrame()

    # ✅ use actual Date
    df["refund_detected_date"] = pd.to_datetime(
        df["refund_detected_date"], utc=True, format="mixed", errors="coerce"
    )
    df = df.dropna(subset=["refund_detected_date"])
    df["refund_detected_date"] = df["refund_detected_date"].dt.tz_convert(
        "America/Los_Angeles"
    )
    df["Date_only"] = df["refund_detected_date"].dt.normalize()

    # ✅ make today same timezone
    today = pd.Timestamp.now(tz="America/Los_Angeles").normalize()

    mtd_start = today.replace(day=1)
    ytd_start = today.replace(month=1, day=1)

    # ---------- mapping ----------
    def map_model(p):
        p_clean = str(p).lower().replace(" ", "").replace("-", "")
        if "modo" in p_clean:
            return "Modo"
        if "c2" in p_clean:
            return "Model C2"
        elif "modelf" in p_clean or p_clean == "f":
            return "Model F"
        elif "r3" in p_clean:
            return "Model R-3 wheel"
        elif "r4" in p_clean:
            return "Model R-4 wheel"
        else:
            return "Other"

    df["Product Type"] = df["product"].apply(map_model)

    def agg(data):
        return data.groupby(["Product Type", "product"])["qty"].sum().reset_index()

    date_df = agg(df[df["Date_only"] == today]).rename(columns={"qty": "Date"})
    mtd_df = agg(
        df[(df["Date_only"] >= mtd_start) & (df["Date_only"] <= today)]
    ).rename(columns={"qty": "MTD"})
    ytd_df = agg(
        df[(df["Date_only"] >= ytd_start) & (df["Date_only"] <= today)]
    ).rename(columns={"qty": "YTD"})

    df_summary = date_df.merge(mtd_df, on=["Product Type", "product"], how="outer")
    df_summary = df_summary.merge(ytd_df, on=["Product Type", "product"], how="outer")

    return df_summary.fillna(0)


